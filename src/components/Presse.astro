---
interface Article {
  image: string;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  titre: string;
  date: string;
}

interface Props {
  titre?: string;
  articles?: Article[];
}

const {
  titre = "La presse en parle !",
  articles = []
} = Astro.props;
---

<section class="presse">
    <div class="presse-contenu">
  <h2 data-aos="fade-up">{titre}</h2>
  <div class="cards-presse">
    {articles.map((article, index) => (
      <div class="card" data-aos="fade-up" data-aos-delay={index * 100}>
        <div class="card-img-zoom">
          <img
            src={article.image}
            alt={article.imageAlt}
            width={article.imageWidth}
            height={article.imageHeight}
            loading="lazy"
          />
        </div>
        <div class="text">
          <h3>{article.titre}</h3>
          <span class="date">Paru le {article.date}</span>
        </div>
      </div>
    ))}
  </div>
    </div>
</section>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Agrandissement de l'image">
  <button class="lightbox-close" id="lightbox-close" aria-label="Fermer">&#x2715;</button>
  <img id="lightbox-img" src="" alt="" />
  <span class="lightbox-hint">Clic ou Échap pour fermer</span>
</div>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('open');
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    lightboxImg.src = '';
  }

  document.querySelectorAll('.card-img-zoom img').forEach((img) => {
    img.addEventListener('click', () => {
      openLightbox((img as HTMLImageElement).src, (img as HTMLImageElement).alt);
    });
  });

  closeBtn.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>


.presse {
  
  padding-block: 2rem;
  background-color: var(--color-bg1);
  color: var(--color-text); 
  width: 100%;
}

.presse-contenu {
  text-align: center;
  max-width: 1300px;   /* ajuster selon la largeur souhaitée */
  margin-inline: auto; /* centre le container horizontalement*/
  padding-inline: clamp(1rem, 5%, 3rem); /*espace intérieur gauche droite : min 16px, idéalement 5% max 48px, s'adapte automoatiquement*/
  box-sizing: border-box;
}

.cards-presse {
  display: flex;
  flex: 1;
  align-items: stretch;
  justify-content: space-between;
  gap: 40px;
  margin: 20px auto 0;
  flex-wrap: wrap;
}

.card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  flex: 1 1 200px;  /* grandit, rétrécit, base de 200px */
  max-width: 300px; /* mais jamais trop large */
}

.card-img-zoom img {
  width: 100%;
  height: auto;
  display: block;
  cursor: zoom-in;
  transition: opacity 0.25s ease;
}

.card-img-zoom img:hover {
  opacity: 0.8;
}

.date {
  font-size: 0.85rem;
  color: var(--color-text);
  opacity: 0.7;
}

/* Lightbox */
.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.88);
  z-index: 999;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  cursor: zoom-out;
}

.lightbox.open {
  display: flex;
  animation: lbIn 0.25s ease forwards;
}

@keyframes lbIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.lightbox img {
  max-width: 90vw;
  max-height: 90vh;
  object-fit: contain;
  border-radius: 0.5rem;
  animation: lbZoom 0.25s ease forwards;
}

@keyframes lbZoom {
  from { transform: scale(0.92); }
  to   { transform: scale(1); }
}

.lightbox-close {
  position: fixed;
  top: 1.25rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: white;
  font-size: 2rem;
  cursor: pointer;
  padding: 0.25rem 0.5rem;
  border-radius: 0.375rem;
  line-height: 1;
}

.lightbox-close:hover {
  background: rgba(255, 255, 255, 0.15);
}

.lightbox-hint {
  position: fixed;
  bottom: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.4);
  font-size: 0.8rem;
  pointer-events: none;
}
@media (max-width: 700px) {
  .cards-presse {
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .card {
    width: 100%;
    max-width: 340px;
  }
}
</style>