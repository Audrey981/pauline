 ---
// H1etTexte.astro
const { titre, texte } = Astro.props;
---
 <div class="hero">
  <div class="container">
    <div class="text-hero" data-aos="fade-right">
      <div class="main-text"><h1>{titre}</h1></div>
      <div class="secondary-text" set:html={texte} />
    </div>
  </div>
</div>


<style>

.hero {
  background-color: var(--color-bg1);  
  display: flex;
  flex: 1;
  margin: 0;
  padding: 0 10%;
  justify-content: space-between;
  align-items: center;
}

.text-hero {
  display: flex;
  flex-direction: column;
  align-items: start;
  max-width: 100%;
  margin: 0;
  padding: 5%;
}

.main-text {
  font-size: 42px;
  color: var(--color-text); 
  margin: 0;
}

.secondary-text {
  font-size: inherit;
  color: var(--color-text);
  margin: 0;
}

@media screen and (max-width: 900px) {
  .hero {
    flex-direction: column;
    align-items: center;
    padding: 0 5%;
    text-align: center;
  }
  .text-hero {
    width: 100%;
    align-items: center;
    margin-bottom: 20px;
  }
 
  .main-text {
    font-size: clamp(28px, 5vw, 42px);
  }
  .secondary-text {
    font-size: inherit;
  }
 
}

</style>