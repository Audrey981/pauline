---
interface Carte {
  image: any;
  imageAlt: string;
  imageWidth: number;
  imageHeight: number;
  titre: string;
  texte: string;
  lien?: string;
}

interface Props {
  titre?: string;
  cartes?: Carte[];
}

const {
  titre = "Mes services",
  cartes = []
} = Astro.props;
---

<section class="services">
  <div class="container">
    <h2>{titre}</h2>
    <div class="cards">
      {cartes.map((carte) => (
        <a href={carte.lien ?? `${import.meta.env.BASE_URL}services`} class="card">
          <img
            src={carte.image.src}
            alt={carte.imageAlt}
            width={carte.imageWidth}
            height={carte.imageHeight}
          />
          <div class="text">
            <strong>{carte.titre}</strong><br />
            {carte.texte}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

    <style>

.services {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  padding: 1rem 2%;
  text-align: center;
  background-color: var(--color-bg2);
  color: var(--color-text);
}
.cards {
  display: flex;
  flex: 1;
  align-items: stretch;
  justify-content: space-between;
  gap: 15px;
  margin: 20px auto 0;
  flex-wrap: wrap;
}

.cards > a {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  width: 220px;
  padding: 16px;
  box-sizing: border-box;
  color: var(--color-text);
  cursor: pointer;
}

.cards img {
  width: 100%;
  max-width: 100%;
  height: auto;
  border-radius: 12px;
  border: 2px solid var(--color-text);
  display: block;
  transition: transform 0.2s ease;
}

.cards > a:hover img {
  transform: scale(1.05);
  filter: brightness(0.85);
}

.cards a {
  font-size: 18px;
}

.cards .card {
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  width: 250px;
  padding: 16px;
  box-sizing: border-box;
  color: #1f2937;
}

.cards > [class*="card-"]:hover img {
  transform: scale(1.05);
  filter: sepia(0.6);
}

@media screen and (max-width: 900px) {
  .services {
    padding: 2rem 0;
  }
  .services .cards {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .card {
    width: 100%;
    max-width: 380px;
    margin: 0 auto;
  }
  .services p,
  .services .text,
  .services a {
    font-size: clamp(15px, 3.8vw, 16px);
    line-height: 1.6;
  }
}

@media (max-width: 700px) {
  .cards > a {
    width: 100%;
    max-width: 320px;
    margin: 0 auto 20px;
  }
  .cards img {
    max-height: 120px !important;
    width: auto !important;
    height: auto !important;
  }
  .cards > a {
    gap: 8px !important;
  }
}
    </style>