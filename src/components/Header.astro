---
// Script : props optionnelles - retravailler quand j'aurai le vrai logo : ne pas laisser l'image et affiner le svg
import Navigation from './Navigation.astro';
//import logo from '../images/generated-image.png';

const {
  altLogo = "Logo",
} = Astro.props;
---
<header>

<div class="header-logo" aria-label={altLogo}>
    <svg
      viewBox="0 0 120 120"
      width="120"
      height="120"
      role="img"
      aria-label={altLogo}
    >
      <circle cx="60" cy="60" r="60" fill="#8C6A2A" />
      <text
        x="50%"
        y="54%"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#FEF5EB"
        font-family="'Cormorant Garamond', 'Times New Roman', serif"
        font-size="62"
        font-weight="600"
      >
        R
      </text>
    </svg>
  <!-- 
<img src={logo.src} alt={altLogo} width="600" height="508"> -->

</div>

<Navigation>

</Navigation>
  
<div class="header-wave" aria-hidden="true">
     <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
    <path
      d="M0,64 C240,20 480,20 720,64 C960,108 1200,108 1440,64 L1440,120 L0,120 Z"
      fill="#FEF5EB"
    />
  </svg>
  </div>

</header>

<style>

header {
  position: relative;
  background: var(--bg-marble); 
  color: var(--color-text-inverse);
  display: flex;
  align-items: center;
  padding-right: 20rem;
  padding-bottom: 4rem;
}
.header-logo {
  display: flex;
  padding: 1rem 15rem;
}
.header-logo img {
  height: 120px;
  width: auto;
  border-radius: 50%;
  overflow: hidden;
}

.header-logo svg {
  height: 120px;
  width: 120px;
  flex-shrink: 0;
}


.header-wave {
  position: absolute;
  left: 0;
  bottom: -1px;
  width: 100%;
  line-height: 0;
  overflow: hidden;
}

.header-wave svg {
  display: block;
  width: 100%;
  height: 42px;
}

@media (max-width: 900px) {
  header {
    padding-right: 1rem;
    padding-bottom: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .header-logo {
    padding: 0.75rem 1rem;
  }

  .header-wave svg {
    height: 28px;
  }
}

@media (max-width: 480px) {
  header {
    padding-right: 0.5rem;
  }
  .header-logo {
    padding: 0.5rem;
  }
  .header-wave svg {
    height: 20px;
  }
}

</style>