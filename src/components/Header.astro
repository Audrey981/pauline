---
// Script : props optionnelles
import Navigation from './Navigation.astro';
import logo from '../images/logo.webp';

const {
  altLogo = "Logo",
} = Astro.props;
---
<header>

<div class="header-logo">
  <img src={logo.src} alt={altLogo} width="600" height="508">
</div>

<Navigation>

</Navigation>
  
</header>

<style>
header {
  background-color: var(--color-bg1); 
  color: var(--color-text);
  display: flex;
  align-items: center;
  padding-right: 20rem;
}
.header-logo {
  background-color: var(--color-bg1) ;
  display: flex;
  padding: 1rem 20rem;
}
.header-logo img {
  height: 280px;
  width: auto;
}
@media (max-width: 900px) {
  header {
    padding-right: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .header-logo {
    padding: 0.75rem 1rem;
  }
}

@media (max-width: 480px) {
  header {
    padding-right: 0.5rem;
  }
  .header-logo {
    padding: 0.5rem;
  }
}

</style>