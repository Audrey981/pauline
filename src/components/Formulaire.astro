---
const { 
  titre = "Formulaire de contact",
  placeholderMessage = "Bonjour ! Décrivez ici votre demande..."
} = Astro.props;
---

<section class="section-formulaire">
  <h2>{titre}</h2>
  <form action="https://api.web3forms.com/submit" method="POST" data-aos="fade-up" id="formulaire-contact">
    
    <!-- Clé API Web3Forms -->
    <input type="hidden" name="access_key" value="a4dd15ab-f21b-47ea-bfce-3eaa565f9ca9" />
    
    <!-- Sujet de l'email reçu -->
    <input type="hidden" name="subject" value="Nouveau message depuis le site Natacha Boxe Thérapie" />

    <!-- Honeypot anti-spam (invisible pour les humains) -->
    <input type="checkbox" name="botcheck" style="display:none;" />

    <ul>
      <li class="ligne-double">
        <div class="champ">
          <label for="name">Nom&nbsp;:</label>
          <input type="text" id="name" name="name" required placeholder="Martin" autocomplete="family-name" />
        </div>
        <div class="champ">
          <label for="prenom">Prénom&nbsp;:</label>
          <input type="text" id="prenom" name="prenom" required placeholder="Julie" autocomplete="given-name" />
        </div>
      </li>
      <li class="ligne-double">
        <div class="champ">
          <label for="mail">E-mail&nbsp;:</label>
          <input type="email" id="mail" name="email" required placeholder="exemple@email.com" autocomplete="email" />
        </div>
        <div class="champ">
          <label for="tel">Téléphone&nbsp;:</label>
          <input type="tel" id="tel" name="telephone" placeholder="06 12 43 66 31" autocomplete="tel" />
        </div>
      </li>
      <li>
        <label for="msg">Message&nbsp;:</label>
        <textarea id="msg" name="message" required placeholder={placeholderMessage}></textarea>
      </li>
      <li class="consentement">
        <input type="checkbox" id="consent" name="consent" required />
        <label for="consent">En cochant cette case, j'accepte d'être recontacté(e).</label>
      </li>
    </ul>

    <button type="submit" class="bouton-fonce">Envoyer le message</button>

    <!-- Messages de retour -->
    <p class="form-success" id="form-success" aria-live="polite">
      ✅ Message envoyé ! Natacha vous répondra dans les plus brefs délais.
    </p>
    <p class="form-error" id="form-error" aria-live="polite">
      ❌ Une erreur est survenue. Merci de réessayer ou de nous contacter directement par téléphone.
    </p>

  </form>
</section>

<style>
  .section-formulaire {
    background-color: var(--color-bg1);
    padding: 2rem;
  }

  .section-formulaire h2 {
    margin-top: 0;
    padding-top: 0;
  }

  form {
    margin: 2rem auto;
    max-width: 600px;
    width: 100%;
    padding: 1.5em;
    border: 1px solid #ccc;
    border-radius: 10px;
    background: var(--bg-marble);
    color: var(--color-text-inverse)
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  form li + li {
    margin-top: 1em;
  }

  .ligne-double {
    display: flex;
    gap: 1rem;
  }

  .champ {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .champ label {
    margin-bottom: 0.3rem;
    text-align: left;
    width: auto;
  }

  .champ input {
    width: 100%;
  }

  li:not(.ligne-double):not(.consentement) label {
    display: block;
    margin-bottom: 0.3rem;
  }

  input,
  textarea {
    font: 1em sans-serif;
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #999;
    border-radius: 4px;
    padding: 0.4rem 0.6rem;
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-text);
    outline: none;
  }

  textarea {
    vertical-align: top;
    height: 5em;
    resize: vertical;
  }

  .consentement {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .consentement input[type="checkbox"] {
    width: auto;
  }

  button.bouton-fonce {
    background-color: var(--color-button);
    border: 2px solid white;
    cursor: pointer;
    font: inherit;
    -webkit-appearance: none;
    appearance: none;
    display: block;
    margin: 1.5rem auto 0;
  }

  input[type="text"]:invalid:not(:placeholder-shown),
  input[type="email"]:invalid:not(:placeholder-shown),
  textarea:invalid:not(:placeholder-shown) {
    border-color: #e53935;
  }

  /* Messages de retour */
  .form-success,
  .form-error {
    display: none;
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 6px;
    text-align: center;
    font-weight: 500;
  }

  .form-success {
    background-color: #d4edda;
    color: #155724;
  }

  .form-error {
    background-color: #f8d7da;
    color: #721c24;
  }

  @media (max-width: 480px) {
    form {
      padding: 1rem;
      width: 95%;
      box-sizing: border-box;
      overflow-x: hidden;
    }

    .ligne-double {
      flex-direction: column;
      gap: 0;
    }

    .ligne-double + .ligne-double {
      margin-top: 0;
    }
  }
</style>

<script>
  const form = document.getElementById('formulaire-contact') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (result.success) {
        successMsg.style.display = 'block';
        errorMsg.style.display = 'none';
        form.reset();
      } else {
        errorMsg.style.display = 'block';
        successMsg.style.display = 'none';
      }
    } catch {
      errorMsg.style.display = 'block';
      successMsg.style.display = 'none';
    }
  });
</script>