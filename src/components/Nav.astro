---
interface Props {
  liens?: { label: string; href: string }[];
}

const { 
  liens = [
     { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
    { label: "À propos", href: `${import.meta.env.BASE_URL}apropos` },
    { label: "Contact", href: `${import.meta.env.BASE_URL}contact` }
  ]
} = Astro.props;

---
<div class="elements">
  <div class="links">
    {liens.map((lien) => (
      <a href={lien.href}>{lien.label}</a>
    ))}
  </div>
</div>

<style>

.elements {
  display: flex;
  justify-content: end;
  margin: 0;
  padding: 0;
  margin-left: auto;
  font-size: 0.90em;
}
.links {
  display: flex;
  gap: 20px;
  
}

.links a {
  font-size: inherit;
  white-space: nowrap; /* ← empêche le retour à la ligne */
}


@media screen and (max-width: 900px) {
  .elements {
    justify-content: center;
  }
  .links a {
    font-size: clamp(14px, 3.5vw, 16px);
  }
}
</style>