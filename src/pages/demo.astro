---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HeroLeft from '../components/HeroLeft.astro';
import BlocTexteImage from '../components/BlocTexteImage.astro';
import BlocTexte from '../components/BlocTexte.astro';
import Servicescards from '../components/Servicescards.astro';
import Avis from '../components/Avis.astro';
import QuestionsFrequentes from '../components/QuestionsFrequentes.astro';
import Slider from '../components/Slider.astro';
import Etapes from '../components/Etapes.astro';
import Action from '../components/Action.astro';
import FilAriane from '../components/FilAriane.astro';
import MembresEquipe from '../components/MembresEquipe.astro';
import Presse from '../components/Presse.astro';
import Formulaire from '../components/Formulaire.astro';
import Zone from '../components/Zone.astro';
import zoneImage from '../images/zone.webp';
import { siteConfig } from '../config/site';

import heroImage from '../images/natacha1.webp';
import sectionImage from '../images/atelier4.webp';
import tonImage from '../images/natacha3.webp';

import natacha3 from '../images/natacha3.webp';
import natacha4 from '../images/natacha4.webp';
import natacha6 from '../images/natacha6.webp';


const slidesDemo = [
  { src: natacha3.src, alt: 'Image de démonstration 1', width: 500, height: 333 },
  { src: natacha4.src, alt: 'Image de démonstration 2', width: 500, height: 333 },
  { src: natacha6.src, alt: 'Image de démonstration 3', width: 600, height: 399 },
];

const etapesDemo = [
  { titre: 'Premier échange', texte: 'Un temps pour comprendre le besoin, le contexte et les objectifs du projet.' },
  { titre: 'Proposition adaptée', texte: 'Une réponse claire avec une structure pensée pour l’activité et les visiteurs.' },
  { titre: 'Mise en place', texte: 'Le projet prend forme, puis il est ajusté avant sa mise en ligne.' },
];
---

<BaseLayout
  title={`Demo composants - ${siteConfig.name}`}
  description="Page de démonstration des composants du starter."
  canonical={`${siteConfig.url}/demo`}
  ogTitle={`Demo composants - ${siteConfig.name}`}
  ogDescription="Page de démonstration des composants du starter."
  schema={null}
>

<FilAriane items={[
  { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
  { label: "Démo composants" }
]} />

  <Hero
    titre="composant hero"
    texte="<p><strong>Cette page permet de tester les composants du starter.</strong></p>
    <p>Elle sert de showroom interne pour vérifier rapidement les variantes, les espacements et le rendu général.</p>"
    image={heroImage}
    imageAlt="Image de démonstration"
    lienLabel="Voir la page contact"
    lienHref={`${import.meta.env.BASE_URL}contact`}
  />

  <HeroLeft
  titre="composant hero left"
  texte={`
    <p>Ici, j'explique simplement votre activité et votre manière d'accompagner vos clients</p>

      <p>Cette section de démonstration sert à montrer comment afficher un texte plus développé, avec plusieurs paragraphes, un sous-titre et une liste de points clés.</p>

    <p>L’idée est de garder une structure réaliste, sans rester sur un contenu trop lié à un projet client précis.</p>

    <h3>Ce que cette section peut mettre en avant</h3>
    <ul>
      <li>Votre façon de travailler</li>
      <li>Les bénéfices pour vos clients</li>
      <li>Votre posture ou votre méthode</li>
      <li>Les éléments qui vous différencient</li>
      <li>Le cadre de votre accompagnement</li>
    </ul>
  `}
  image={tonImage}
  imageAlt="image de démonstration"
/>

  <BlocTexteImage
    titre="Bloc texte + image"
    texte="<h3>Une section de démonstration</h3>
    <p>Ce bloc permet de tester l’affichage d’un titre, d’un texte enrichi et d’une image dans une mise en page éditoriale simple.</p>
    <h3>Pourquoi il est utile</h3>
    <p>Il peut être réutilisé pour une présentation, une méthode, un service ou un à-propos.</p>"
    image={sectionImage}
    imageAlt="Section de démonstration"
  />

  <Servicescards
    titre="Cartes de services"
    cartes={[
      { image: natacha3, imageAlt: 'Service 1', imageWidth: 354, imageHeight: 354, titre: 'Service 1', texte: 'Description courte du service proposé.', lien: `${import.meta.env.BASE_URL}contact` },
      { image: natacha4, imageAlt: 'Service 2', imageWidth: 220, imageHeight: 221, titre: 'Service 2', texte: 'Un deuxième bloc pour tester la grille.', lien: `${import.meta.env.BASE_URL}contact` },
      { image: natacha6, imageAlt: 'Service 3', imageWidth: 343, imageHeight: 343, titre: 'Service 3', texte: 'Une autre carte de démonstration.', lien: `${import.meta.env.BASE_URL}contact` },
      { image: natacha6, imageAlt: 'Service 4', imageWidth: 310, imageHeight: 310, titre: 'Service 4', texte: 'Carte supplémentaire pour vérifier l’équilibre visuel.', lien: `${import.meta.env.BASE_URL}contact` }
    ]}
  />
<MembresEquipe
  titre="Exemple de bloc valeurs<br><em>Une autre manière de présenter une posture ou des engagements</em>"
  membres={[
    {
      nom: "Clarté",
      icone: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.75c.63.47 1 1.2 1 2V18h6v-1.25c0-.8.37-1.53 1-2A7 7 0 0 0 12 2z"/></svg>`
    },
    {
      nom: "Écoute",
      icone: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 1 6 6c0 4-4 4-4 8a2 2 0 1 1-4 0"/><path d="M9 9a3 3 0 0 1 6 0"/></svg>`
    },
    {
      nom: "Adaptation",
      icone: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 13.66-5.66"/><path d="M20 4v6h-6"/><path d="M20 12a8 8 0 0 1-13.66 5.66"/><path d="M4 20v-6h6"/></svg>`
    },
    {
      nom: "Respect",
      icone: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-4.35-9-8.5C.5 9.5 2.5 5 7 5c2 0 3.2 1 5 3 1.8-2 3-3 5-3 4.5 0 6.5 4.5 4 7.5-3 4.15-9 8.5-9 8.5z"/></svg>`
    }
  ]}
/>

  <Etapes
    titre="Étapes d’un projet"
    intro="Cette section permet de visualiser un déroulé simple en plusieurs étapes."
    etapes={etapesDemo}
  />

  <BlocTexte
    titre="Bloc texte simple"
    description="<h3>Un contenu plus direct</h3>
    <p>Ce composant peut servir pour des tarifs, une présentation synthétique, une offre ou une explication complémentaire.</p>"
    boutonTexte="Prendre contact"
    boutonLien={`${import.meta.env.BASE_URL}contact`}
  />

  <Avis
    titre="Avis de démonstration"
    avis={[
      { texte: 'Cette section permet de tester le rendu des témoignages sur plusieurs cartes.', auteur: 'Claire' },
      { texte: 'Les textes peuvent être plus ou moins longs selon les besoins du projet.', auteur: 'Julien' },
      { texte: 'Le composant reste utile pour valider l’équilibre visuel de la section.', auteur: 'Sophie' }
    ]}
  />

  <QuestionsFrequentes
    questions={[
      { question: 'À quoi sert cette page ?', reponse: 'Elle sert à tester rapidement les composants du starter dans une page unique.' },
      { question: 'Faut-il la laisser dans le site final ?', reponse: 'Pas forcément. Elle peut rester en phase de développement puis être retirée avant la mise en ligne.' },
      { question: 'Peut-on y ajouter d’autres composants ?', reponse: 'Oui, cette page est faite pour évoluer avec ton starter.' }
    ]}
  />

  <Formulaire
  action="/traitement-demo"
  placeholderMessage="Bonjour ! Décrivez ici votre demande ou votre projet..."
/>

  <Slider
    slides={slidesDemo}
    title="Galerie de démonstration"
    subtitle="Une galerie simple pour vérifier le rendu visuel et le comportement du slider."
  />
<Zone
  titre="Exemple de zone d’intervention"
  image={zoneImage}
  imageAlt="Carte de démonstration de la zone d’intervention"
  imageWidth={823}
  imageHeight={492}
  carteUrl="https://www.google.com/maps"
/>

<Presse
  titre="Exemple de bloc presse"
  articles={[
    {
      image: `${import.meta.env.BASE_URL}presse1.jpeg`,
      imageAlt: "Exemple de visuel presse 1",
      imageWidth: 220,
      imageHeight: 510,
      titre: "Nom du média",
      date: "01/01/2026"
    },
    {
      image: `${import.meta.env.BASE_URL}presse2.jpeg`,
      imageAlt: "Exemple de visuel presse 2",
      imageWidth: 450,
      imageHeight: 521,
      titre: "Nom du média",
      date: "15/02/2026"
    },
    {
      image: `${import.meta.env.BASE_URL}presse3.jpeg`,
      imageAlt: "Exemple de visuel presse 3",
      imageWidth: 450,
      imageHeight: 629,
      titre: "Nom du média",
      date: "20/03/2026"
    }
  ]}
/>

  <Action
    titre="Fin de la démonstration"
    texte="Cette dernière section permet aussi de tester le composant d’appel à l’action."
    lienLabel="Retour au contact"
    lienHref={`${import.meta.env.BASE_URL}contact`}
  />
</BaseLayout>