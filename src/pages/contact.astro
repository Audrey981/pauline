---
import BaseLayout from '../layouts/BaseLayout.astro';
import FilAriane from '../components/FilAriane.astro';
import Hero from '../components/Hero.astro';
import Formulaire from '../components/Formulaire.astro';
import Zone from '../components/Zone.astro';
import { siteConfig } from '../config/site.ts';
import monImage from '../images/gants.webp';
import carteZone from '../images/zone.webp';

const base = import.meta.env.BASE_URL;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "url": `${siteConfig.url}/contact`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteConfig.url },
      { "@type": "ListItem", "position": 2, "name": "Contact", "item": `${siteConfig.url}contact` }
    ]
  }
]
---

<BaseLayout
  title="Contacter Natacha - Boxe thérapeute à Saumur"
  description="Contactez Natacha, boxe thérapeute à Saumur. Par téléphone, email ou formulaire. Réponse rapide à chaque message."
  canonical={`${siteConfig.url}contact`}
  ogTitle={`Contacter ${siteConfig.name}`}
  ogDescription={`Contactez ${siteConfig.name} pour toute question sur la boxe thérapie.`}
  schema={schema}
>
  <FilAriane items={[
    { label: "Accueil", href: `${import.meta.env.BASE_URL}` },
    { label: "Contact" }
  ]} />
  
  <Hero 
     titre="Infos pratiques et contact"
    texte={`<h2>Une question, un projet, envie d'en savoir plus ?</h2>
    <p>Écris-moi ou appelle-moi directement. Je réponds à chaque message avec attention.<br>
    📞  06 84 55 69 02 <br>
    📧  <a href="mailto:nat.boxetherapie@gmail.com">nat.boxetherapie@gmail.com</a> </p>
    <div class="reseaux">
  <a href="https://www.instagram.com/natacha.boxetherapie" target="_blank" rel="noopener">
    <img src="__BASE__icons/instagram.svg" alt="Instagram" width="22" height="22" />
    natacha.boxetherapie
  </a> <br>
  <a href="https://www.facebook.com/profile.php?id=61561327531815" target="_blank" rel="noopener">
    <img src="__BASE__icons/facebook.svg" alt="Facebook" width="22" height="22" />
    natacha.boxetherapie
  </a>
</div>
    `}
    image={monImage}
    imageAlt="image de Natacha, boxe thérapeute à saumur"
    lienLabel="Découvrez la boxe thérapie"
    lienHref={`${import.meta.env.BASE_URL}`}
  />
    

  <Formulaire
    action="/traitement-natacha"
    placeholderMessage="Bonjour ! Décrivez ici votre demande..."
  />

  <Zone 
      titre="Ma zone d'intervention"
      image={carteZone}
      imageAlt="carte de la zone d'intervention de Natacha Boxe thérapie à Saumur"
      carteUrl="https://share.google/MIFRXhOpA1wNrpwJp"
  />

</BaseLayout>